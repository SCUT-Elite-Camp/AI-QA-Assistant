# LLM_API_KEY=
# LLM_API_BASE=https://api.openai.com/v1
# LLM_MODEL=gpt-3.5-turbo
# LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=2000
# LLM_TIMEOUT=30
