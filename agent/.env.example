USE_MOCK_RETRIEVAL=true
USE_MOCK_LLM=true
DEFAULT_TOP_K=5
MIN_RETRIEVAL_SCORE=0.0
DEFAULT_RETRIEVAL_MODE=hybrid
TOOL_LAYER_IMPORT=tool_layer
TOOL_LAYER_CLASS=SearchTool
AGENT_PORT=8000
LOG_LEVEL=INFO

# 真实 LLM 模式需要显式关闭 Mock，并通过环境变量提供兼容 OpenAI Chat Completions 的服务配置。
